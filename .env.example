# SCC Backend env — copy to /opt/scc-backend/.env on the VPS and fill real values there.
# Do not commit real secrets.

# Public hosts. If there is no real domain yet, use <vps-ip>.sslip.io names.
API_HOST=api.<vps-ip>.sslip.io
STORAGE_HOST=storage.<vps-ip>.sslip.io
CADDY_EMAIL=admin@example.com

# Backend API
PORT=8080
ENV=production
# Use the exact Vercel domain later. During bootstrap, * is supported and echoes the request origin.
CORS_ORIGINS=*
JWT_SECRET=<long-random-secret>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# VPS PostgreSQL container managed by scripts/deploy-vps.sh
POSTGRES_DB=smartcover
POSTGRES_USER=smartcover
POSTGRES_PASSWORD=<strong-postgres-password>
# URL-encode POSTGRES_PASSWORD inside DATABASE_URL if it contains URL-reserved characters.
DATABASE_URL=postgresql://smartcover:<url-encoded-postgres-password>@scc-postgres:5432/smartcover?sslmode=disable

# VPS MinIO container managed by scripts/deploy-vps.sh and published by Caddy HTTPS.
MINIO_ROOT_USER=<minio-root-user>
MINIO_ROOT_PASSWORD=<strong-minio-root-password>
MINIO_ENDPOINT=storage.<vps-ip>.sslip.io
MINIO_ACCESS_KEY=<minio-root-user>
MINIO_SECRET_KEY=<strong-minio-root-password>
MINIO_BUCKET=scc
MINIO_PUBLIC_URL=https://storage.<vps-ip>.sslip.io
MINIO_USE_SSL=true
# best-effort keeps deploy unblocked if the installed MinIO/mc version cannot apply bucket CORS.
# Use "required" only after verifying that bucket CORS is supported on the VPS image pair.
MINIO_CONFIGURE_CORS=best-effort

# Production currently uses app startup AutoMigrate because the DB is private on the VPS.
# Keep SEED_DATA=false unless intentionally bootstrapping a fresh environment.
AUTO_MIGRATE=true
SEED_DATA=false
