# SCC Backend local env — fill real values later
# Cloud Run will use secrets/env vars, not this file directly.
DATABASE_URL=
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# R2 is S3-compatible; current code still uses MINIO_* names.
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_PUBLIC_URL=
MINIO_USE_SSL=true

CORS_ORIGINS=
PORT=8080
ENV=development
SEED_DATA=false
