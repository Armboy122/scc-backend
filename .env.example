# SCC Backend env — copy to /opt/scc-backend/.env on the VPS and fill real values there.
# Do not commit real secrets.

# Public hosts. If there is no real domain yet, use <vps-ip>.sslip.io names.
API_HOST=api.<vps-ip>.sslip.io
STORAGE_HOST=storage.<vps-ip>.sslip.io
CADDY_EMAIL=admin@example.com

# Backend API
PORT=8080
ENV=production
# Use the exact deployed Vercel HTTPS origin. Wildcard CORS is forbidden in production.
CORS_ORIGINS=https://<vercel-production-domain>
JWT_SECRET=<long-random-secret>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
# Phase 2 borrow routes and maintenance stay unavailable until explicitly enabled.
ENABLE_PHASE2_BORROWING=false
# Exactly one active production API instance owns scheduled jobs; deploy candidates override this to false.
RUN_BACKGROUND_JOBS=true

# VPS PostgreSQL container managed by scripts/deploy-vps.sh
POSTGRES_DB=smartcover
POSTGRES_USER=smartcover
POSTGRES_PASSWORD=<strong-postgres-password>
# Resolve and record a reviewed multi-platform digest; production deploys reject mutable tags.
POSTGRES_IMAGE=postgres@sha256:<postgres-16-alpine-manifest-digest>
# URL-encode POSTGRES_PASSWORD inside DATABASE_URL if it contains URL-reserved characters.
DATABASE_URL=postgresql://smartcover:<url-encoded-postgres-password>@scc-postgres:5432/smartcover?sslmode=disable

# Private VPS MinIO bucket. Internal stat/readiness never depends on Caddy;
# browser PUT/GET URLs are signed against the public HTTPS host.
MINIO_ROOT_USER=<minio-root-user>
MINIO_ROOT_PASSWORD=<strong-minio-root-password>
MINIO_INTERNAL_ENDPOINT=scc-minio:9000
MINIO_INTERNAL_USE_SSL=false
MINIO_PUBLIC_ENDPOINT=storage.<vps-ip>.sslip.io
MINIO_PUBLIC_USE_SSL=true
# Runtime API/backup service account. Bootstrap may temporarily use the root
# pair, but production must rotate these with docs/MINIO_SERVICE_ACCOUNT_ROTATION.md.
MINIO_ACCESS_KEY=<minio-application-service-account-access-key>
MINIO_SECRET_KEY=<minio-application-service-account-secret-key>
MINIO_BUCKET=scc
# Evidence accepts only JPEG/PNG/WebP images from 1 byte through 10 MiB.
# Unsupported bucket CORS falls back to the exact global API cors_allow_origin setting.
# best-effort continues only if both mechanisms fail; required makes that combined failure fatal.
# A changed global value triggers one controlled MinIO restart and a post-restart read-back.
MINIO_CONFIGURE_CORS=best-effort
MINIO_IMAGE=minio/minio@sha256:<reviewed-minio-manifest-digest>
MINIO_MC_IMAGE=minio/mc@sha256:<reviewed-minio-client-manifest-digest>

# Public edge image is immutable too; the deploy records its resolved image ID.
CADDY_IMAGE=caddy@sha256:<reviewed-caddy-manifest-digest>

# Production schema authority is the one-shot `/app/scc-migrate check -> up -> status` flow.
# API startup rejects AUTO_MIGRATE=true and any non-current migration ledger.
AUTO_MIGRATE=false
SEED_DATA=false
